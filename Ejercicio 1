//Escriba un diagrama de ujo tal que dado como datos dos n ́umeros y calcular la suma, resta y multiplicaci ́on de dichos n ́umeros.

#include <stdio.h>
int num1;
int num2;

int main ()
{
  printf("\tEste es un programa que te ayuda a saber las suma, resta y multiplicacion de dos números enteros\n");
  printf("Ingrese dos numeros cualquiera separados por un espacio\n");
  scanf("%d %d",&num1,&num2);
  
  printf("la suma de los numeros %d y %d es: %d\n", num1, num2 ,(num1 + num2));
  printf ("la resta de los numeros de %d y %d es: %d\n", num1, num2, (num1-num2));
  printf ("la multiplicacion de los numeros %d y %d es: %d", num1, num2, (num1*num2));
}
