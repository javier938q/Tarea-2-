/*Construya un diagrama de flujo que lea 100 n ́umeros reales y cuente
cuantos de ellos son positivos, negativos o nulos.*/

#include <stdio.h>
int i, p, n, neu,num;
int main()
{
  printf("Este es un programa que lee 100 numeros reales y te dice cuantos de ello son positivos y cuantos son negativos\n");
  printf("Ingrese los 100 valores\n");
  for (i=0;i<100;i++)
    {
      scanf("%d",&num);
      if(num>0);
      {
        if(num>0)
          {
            p=p+1;
          }   
        else
        {
          n=n+1;
        }
      }
      if(num==0)
      {
       neu=neu+1;
      }
    }
  printf("hay %d numero positivo\n",p);
  printf("hay %d numero negativos\n",n);
  printf("hay %d numero neutros\n",neu);
}
  




    
  

}
