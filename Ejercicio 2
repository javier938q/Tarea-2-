//Construir un diagrama de ujo tal que dado el radio de un c ́ırculo, calcule
//e imprima el  ́area y la circunferencia. El  ́area del c ́ırculo se calcula como
//Area = π ∗ radio2 y la circunferencia se calcula como Circunferencia =
//r*2 ∗ π ∗ radio.

#include <stdio.h>

double radio;
double pi= 3.141516;
int main()
{
  printf( "\tEste es un programa que calcula el area y la circunferencias de un circulo\n");
  printf("De el valor del radio de la circunferencia\n");
  scanf ("%lf", &radio);
  if(radio>0)
  {
   double area = pi*radio*radio;
   double circunferencia = 2*pi*radio;

   printf("Para una circunferencia de radio %.2f\n",radio);
   printf("el área es %.2f\n",area);
   printf("La circunferencia es %.2f\n",circunferencia);
  }
  else
  {
   printf("El valor del radio tiene que ser positivo\n");
  }
  

}

  
