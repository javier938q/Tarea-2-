double desc=0.08;
int main()
{
  printf("bienvenido al elektronicsmx\n");
  printf("Ingrese el monto total de la compra del cliente\n");
  scanf ("%lf",&compra);
  if (compra>2500)
  {
    descuento=compra*desc;
    precioespecial=compra-descuento;
    printf("El precio original es de %g pesos pero con el descuento es de %g pesos\n",compra, precioespecial);
    printf("ahorraste %g pesos\n",descuento); 
