/*Construir un diagrama de ¯Çüujo que pueda determinar, dados dos n ╠üumeros
enteros, si un n ╠üumero es divisor del otro.*/

#include <stdio.h>
int num1;
int num2;
int main()
{
  printf("Este es un programa que te ayuda a sabaer si dos numeros son divisores entre si\n");
  printf("Ingrese los dos numeros\n;
  scanf("%d %d",&num1,&num2);
