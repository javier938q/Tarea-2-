n ╠üumero entero N, comenzando desde el 1.*/

#include <stdio.h>
int i, num, e;
int main()
{
  printf("Este es un programa que imprime la tabla de multiplicar de un numero dado\n");
  printf("De el numero del que quire saber la tabla de multiplicar\n");
  scanf("%d",&num);
  printf("La tabla de multiplicar del numero %d\n");
  for(i=1; i<=10; i++)
  {
    e=num*i;
    printf("%d\n",e);
  }
}


